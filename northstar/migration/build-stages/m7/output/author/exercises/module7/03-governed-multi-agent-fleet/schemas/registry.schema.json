{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sans-python.dev/schemas/swe-fleet-registry.schema.json",
  "title": "SWE Fleet Registry",
  "description": "The machine-readable contract for a governed multi-agent fleet. A malformed registry fails this schema before it governs anything. Validated by a pure-Python checker (schema.py) so the smoke path needs no jsonschema dependency.",
  "type": "object",
  "required": ["fleet", "version", "team_daily_usd", "agents"],
  "additionalProperties": true,
  "properties": {
    "fleet": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "team_daily_usd": {"type": "number", "exclusiveMinimum": 0},
    "kill_switch": {"type": "string"},
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/agent"}
    },
    "fleet_gates": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["id", "role", "owner", "autonomy_tier", "permissions", "budget_daily_usd"],
      "additionalProperties": true,
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "role": {
          "type": "string",
          "enum": ["architect", "coder", "reviewer", "tester"]
        },
        "owner": {"type": "string", "minLength": 1},
        "autonomy_tier": {
          "type": "string",
          "enum": ["F0", "F1", "F2", "F3"],
          "description": "F0 manual ... F3 fully autonomous. A new agent ships low; promotion is a reviewed change to this file."
        },
        "status": {"type": "string", "enum": ["active", "retired", "experimental"]},
        "description": {"type": "string"},
        "permissions": {
          "type": "object",
          "required": ["tools", "can_write_code", "can_merge"],
          "additionalProperties": false,
          "properties": {
            "tools": {"type": "array", "items": {"type": "string"}},
            "can_write_code": {"type": "boolean"},
            "can_merge": {"type": "boolean"}
          }
        },
        "budget_daily_usd": {"type": "number", "exclusiveMinimum": 0},
        "human_gates": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
