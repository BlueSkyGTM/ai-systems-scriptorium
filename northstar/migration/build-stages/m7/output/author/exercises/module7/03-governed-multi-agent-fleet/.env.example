# Real-model path is OPT-IN. The smoke run and tests need none of this —
# they run a governed 5-agent team on deterministic mocks, standard library only.
#
# To drive one or more nodes with a live model instead of the mock:
#   1. pip install anthropic
#   2. copy this file to .env and fill in your key
#   3. pass live models per agent into Fleet.ship_feature(..., models={...}):
#        from client_llm import AnthropicLLM
#        fleet.ship_feature("my feature", project_root, models={
#            "coder-1": AnthropicLLM(), "coder-2": AnthropicLLM()})
#      Leave the architect/reviewer/tester on the cheap mocks, or give them a
#      cheaper model id — the governance does not change.
#
# ANTHROPIC_API_KEY=sk-ant-...
