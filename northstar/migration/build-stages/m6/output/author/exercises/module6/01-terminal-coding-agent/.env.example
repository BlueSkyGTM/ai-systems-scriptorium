# Real-model path is OPT-IN. The smoke run and tests need none of this —
# they run on the deterministic mock with the standard library only.
#
# To drive the loop with a live model instead of the mock:
#   1. pip install anthropic
#   2. copy this file to .env and fill in your key
#   3. wire AnthropicLLM() from client_llm.py in place of MockLLM() in smoke.py
#
# ANTHROPIC_API_KEY=sk-ant-...
