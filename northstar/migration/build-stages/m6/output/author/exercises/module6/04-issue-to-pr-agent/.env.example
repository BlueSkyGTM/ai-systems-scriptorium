# Issue-to-PR agent — optional real-GitHub config.
#
# The smoke path needs NONE of this. It runs on a local git repo with a mock
# coder and your local `git`, fully offline. Set these only when you opt in to
# running against a real fork (see README.md → "Extend to real GitHub").

# A FINE-GRAINED personal access token, scoped to ONE fork you own, with the
# narrowest permissions that work: Contents (read/write) + Pull requests
# (read/write) on that single repo. No org access. No classic tokens.
GITHUB_TOKEN=

# owner/repo of the fork the agent may open PRs against.
GITHUB_REPO=

# Set to 1 to draft fixes with a real model instead of the mock coder.
# Requires `anthropic` installed and ANTHROPIC_API_KEY set.
USE_REAL_LLM=0
ANTHROPIC_API_KEY=
