# Real-time voice assistant — provider keys (ALL OPTIONAL).
#
# The smoke path and tests need NONE of these: `python smoke.py` and
# `python -m pytest tests/` run on the standard library alone with mock stages
# and simulated latency. Fill these in only when you swap a mock stage for a
# real provider (the "extend to Pipecat/LiveKit" path in the README).
#
# Copy to `.env` and fill in the providers you actually use.

# --- STT (speech to text) ---
DEEPGRAM_API_KEY=

# --- LLM (the reply) ---
# Current Anthropic model id: claude-opus-4-8 (use a fast Sonnet for voice latency).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- TTS (text to speech) ---
CARTESIA_API_KEY=

# --- Transport (WebRTC) ---
DAILY_API_KEY=

# --- The latency budget (the enforced gate), mouth to ear, in ms ---
VOICE_BUDGET_MS=600
