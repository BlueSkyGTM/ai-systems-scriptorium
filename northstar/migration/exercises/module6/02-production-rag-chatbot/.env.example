# Production RAG Chatbot -- optional real services.
# Copy to .env and fill in to swap the offline defaults for real backends.
# NONE of these are required: `python smoke.py` and the tests run with the
# standard library alone and never read this file.

# --- Retriever backend (the swappable seam) --------------------------------
# Default is the pure-Python in-memory index. To use Azure AI Search instead,
# set these and call index.build_azure_search_index(chunks) in your wiring.
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=regulated-rag

# --- Generator (the answer model) ------------------------------------------
# Default is the deterministic mock LLM. To use a real model, set a key and
# pass the matching generator (e.g. chatbot.anthropic_llm) to Chatbot(...).
ANTHROPIC_API_KEY=
# Set the current model id (verify via the claude-api skill; do not guess).
ANTHROPIC_MODEL=

# Azure OpenAI alternative for the generator:
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
